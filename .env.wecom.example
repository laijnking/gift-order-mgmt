# ============================================================
# WeCom Plugin Environment Variables
# 企业微信插件配置
# ============================================================

# 是否启用 WeCom Worker (后台任务处理器)
# 设置为 "true" 启用，"false" 禁用
WECOM_WORKER_ENABLED=false

# 文件下载目录 (可选，默认 /tmp/wecom-files)
# WECOM_DOWNLOAD_DIR=/tmp/wecom-files

# 单个文件最大大小 (MB)
WECOM_MAX_FILE_SIZE_MB=10
