          "phone": "13800138000",
          "address": "上海市浦东新区世纪大道100号"
        },
        "items": [
          {
            "orderNo": "BATCH-001",
            "productName": "礼品A",
            "quantity": 1
          },
          {
            "orderNo": "BATCH-001",
            "productName": "礼品B",
            "quantity": 2
          },
          {
            "orderNo": "BATCH-002",
            "productName": "礼品C",
            "quantity": 1
          }
        ]
      },
      "expected": {
        "createdCount": 2,
        "totalSkipped": 1,
        "batchDuplicateCount": 1,
